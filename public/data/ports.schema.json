{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naval-data.local/schemas/port.schema.json",
  "title": "Port",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nullableText": {
      "type": ["string", "null"]
    },
    "nullableNonNegativeNumber": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "latitude": {
      "type": "number",
      "minimum": -90,
      "maximum": 90
    },
    "longitude": {
      "type": "number",
      "minimum": -180,
      "maximum": 180
    },
    "coordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lon"],
      "properties": {
        "lat": { "$ref": "#/$defs/latitude" },
        "lon": { "$ref": "#/$defs/longitude" }
      }
    },
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["north", "south", "east", "west"],
      "properties": {
        "north": { "$ref": "#/$defs/latitude" },
        "south": { "$ref": "#/$defs/latitude" },
        "east": { "$ref": "#/$defs/longitude" },
        "west": { "$ref": "#/$defs/longitude" }
      }
    }
  },
  "required": [
    "name",
    "country",
    "type",
    "bounds",
    "location",
    "nearest_city",
    "operator",
    "max_ship_length_m",
    "max_ship_beam_m",
    "max_draught_m",
    "berth_depth_m",
    "channel_depth_m",
    "carrier_capable",
    "notes",
    "wikipedia_url"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "country": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "enum": ["commercial", "military", "dual_use", "shipyard", "terminal"]
    },
    "bounds": {
      "$ref": "#/$defs/bounds"
    },
    "location": {
      "$ref": "#/$defs/coordinate"
    },
    "nearest_city": {
      "$ref": "#/$defs/nullableText"
    },
    "operator": {
      "$ref": "#/$defs/nullableText"
    },
    "max_ship_length_m": {
      "$ref": "#/$defs/nullableNonNegativeNumber"
    },
    "max_ship_beam_m": {
      "$ref": "#/$defs/nullableNonNegativeNumber"
    },
    "max_draught_m": {
      "$ref": "#/$defs/nullableNonNegativeNumber"
    },
    "berth_depth_m": {
      "$ref": "#/$defs/nullableNonNegativeNumber"
    },
    "channel_depth_m": {
      "$ref": "#/$defs/nullableNonNegativeNumber"
    },
    "carrier_capable": {
      "enum": ["yes", "no", "limited", "unknown"]
    },
    "notes": {
      "$ref": "#/$defs/nullableText"
    },
    "wikipedia_url": {
      "type": ["string", "null"],
      "format": "uri"
    }
  }
}
