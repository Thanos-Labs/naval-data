{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naval-data.local/schemas/ship.schema.json",
  "title": "Carrier",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nullableText": {
      "type": ["string", "null"]
    },
    "nullableDate": {
      "type": ["string", "null"],
      "pattern": "^(\\d{4}|\\d{4}-\\d{2}-\\d{2})$"
    },
    "nullableNonNegativeNumber": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["m", "ft"],
      "properties": {
        "m": { "$ref": "#/$defs/nullableNonNegativeNumber" },
        "ft": { "$ref": "#/$defs/nullableNonNegativeNumber" }
      }
    },
    "speedMeasurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["knots", "km_h"],
      "properties": {
        "knots": { "$ref": "#/$defs/nullableNonNegativeNumber" },
        "km_h": { "$ref": "#/$defs/nullableNonNegativeNumber" }
      }
    },
    "displacementMeasurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tons", "tonnes"],
      "properties": {
        "tons": { "$ref": "#/$defs/nullableNonNegativeNumber" },
        "tonnes": { "$ref": "#/$defs/nullableNonNegativeNumber" }
      }
    }
  },
  "required": [
    "id",
    "name",
    "mmsi",
    "proper",
    "comm",
    "pennant",
    "deck",
    "type",
    "country",
    "navy",
    "class",
    "home_port",
    "img",
    "displacement",
    "length",
    "beam",
    "draught",
    "speed"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "mmsi": {
      "type": ["integer", "null"],
      "minimum": 100000000,
      "maximum": 999999999
    },
    "proper": {
      "type": "string",
      "minLength": 1
    },
    "comm": {
      "$ref": "#/$defs/nullableDate"
    },
    "pennant": {
      "$ref": "#/$defs/nullableText"
    },
    "deck": {
      "$ref": "#/$defs/nullableText"
    },
    "type": {
      "enum": ["aircraft", "helicopter"]
    },
    "country": {
      "type": "string",
      "minLength": 1
    },
    "navy": {
      "type": "string",
      "minLength": 1
    },
    "class": {
      "$ref": "#/$defs/nullableText"
    },
    "home_port": {
      "$ref": "#/$defs/nullableText"
    },
    "img": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "displacement": {
      "$ref": "#/$defs/displacementMeasurement"
    },
    "length": {
      "$ref": "#/$defs/measurement"
    },
    "beam": {
      "$ref": "#/$defs/measurement"
    },
    "draught": {
      "$ref": "#/$defs/measurement"
    },
    "speed": {
      "$ref": "#/$defs/speedMeasurement"
    }
  }
}
