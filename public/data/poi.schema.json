{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naval-data.local/schemas/poi.schema.json",
  "title": "Point of Interest",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["north", "south", "east", "west"],
      "properties": {
        "north": { "type": "number", "minimum": -90, "maximum": 90 },
        "south": { "type": "number", "minimum": -90, "maximum": 90 },
        "east": { "type": "number", "minimum": -180, "maximum": 180 },
        "west": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lon"],
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    }
  },
  "required": [
    "id",
    "name",
    "proper",
    "type",
    "country",
    "operator",
    "bounds",
    "center",
    "carriers"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]{2}-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "proper": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "enum": ["naval_base", "shipyard", "port"]
    },
    "country": {
      "type": "string",
      "minLength": 1
    },
    "operator": {
      "type": ["string", "null"]
    },
    "bounds": {
      "$ref": "#/$defs/bounds"
    },
    "center": {
      "$ref": "#/$defs/point"
    },
    "carriers": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    }
  }
}
