{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naval-data.local/schemas/aoi.schema.json",
  "title": "Area of Interest",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nullableText": {
      "type": ["string", "null"]
    },
    "latitude": {
      "type": "number",
      "minimum": -90,
      "maximum": 90
    },
    "longitude": {
      "type": "number",
      "minimum": -180,
      "maximum": 180
    },
    "coordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lon"],
      "properties": {
        "lat": { "$ref": "#/$defs/latitude" },
        "lon": { "$ref": "#/$defs/longitude" }
      }
    },
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["north", "south", "east", "west"],
      "properties": {
        "north": { "$ref": "#/$defs/latitude" },
        "south": { "$ref": "#/$defs/latitude" },
        "east": { "$ref": "#/$defs/longitude" },
        "west": { "$ref": "#/$defs/longitude" }
      }
    },
    "poly": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/coordinate" }
    }
  },
  "required": [
    "id",
    "name",
    "type",
    "region",
    "bounds",
    "poly",
    "strategic_value",
    "carrier_navigable",
    "notes",
    "wiki_url"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "enum": ["chokepoint", "canal", "sea_lane", "operating_area"]
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "bounds": {
      "$ref": "#/$defs/bounds"
    },
    "poly": {
      "$ref": "#/$defs/poly"
    },
    "strategic_value": {
      "enum": ["low", "medium", "high", "critical"]
    },
    "carrier_navigable": {
      "type": ["boolean", "null"]
    },
    "notes": {
      "$ref": "#/$defs/nullableText"
    },
    "wiki_url": {
      "type": ["string", "null"],
      "format": "uri"
    }
  }
}
